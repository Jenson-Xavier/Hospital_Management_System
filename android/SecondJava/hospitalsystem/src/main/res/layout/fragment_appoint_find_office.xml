<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".AppointFindOfficeFragment"
    android:layout_marginTop="30dp">

    <include layout="@layout/top_back_bar" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/Snow3" >

        <EditText
            android:id="@+id/et_find_office"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/edittext_selector"
            android:hint="搜索科室"
            android:paddingLeft="40dp"
            android:imeOptions="actionSearch"
            android:singleLine="true"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignLeft="@+id/et_find_office"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:src="@drawable/ic_office_search" />

    </RelativeLayout>

    <TextView
        android:id="@+id/tv_nomatch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:textSize="18sp"
        android:text="找不到科室"
        android:textColor="@color/black"
        android:background="@color/Azure"
        android:visibility="gone"
        tools:visibility="visible" />


    <ListView
        android:id="@+id/lv_office"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>