<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".DoctorInfoFindScheduleFragment"
    android:layout_marginTop="30dp">

    <include layout="@layout/top_back_bar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/Snow3">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:gravity="left"
            android:text="就诊日期"
            android:textSize="16dp"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="40dp">

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="点击选择时间"
                android:textSize="18sp"
                android:background="@drawable/edittext_selector" />

            <ImageView
                android:id="@+id/iv_clear_text"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_alignRight="@+id/tv_date"
                android:layout_marginRight="10dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_appointment_clear_text" />


        </RelativeLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/Snow3">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:gravity="left"
            android:text="就诊时段"
            android:textSize="16dp"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="40dp">

            <Spinner
                android:id="@+id/sp_period"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_centerVertical="true"
                android:textSize="18sp"
                android:background="@drawable/edittext_selector"
                android:spinnerMode="dropdown" />

            <ImageView
                android:id="@+id/iv_search"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginRight="10dp"
                android:layout_alignRight="@+id/sp_period"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_office_search" />

        </RelativeLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_nomatch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:textSize="18sp"
        android:text="找不到符合条件的预约记录"
        android:textColor="@color/black"
        android:background="@color/Azure"
        android:visibility="gone"
        tools:visibility="visible" />

    <ListView
        android:id="@+id/lv_schedule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />


</LinearLayout>