<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".CommentMineFragment"
    android:layout_marginTop="30dp">

    <include layout="@layout/top_back_bar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal" >

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="7"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/Snow3">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:gravity="left"
                    android:text="发布日期"
                    android:textSize="16dp"
                    android:textStyle="bold" />

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="40dp">

                    <TextView
                        android:id="@+id/tv_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="点击选择时间"
                        android:textSize="18sp"
                        android:background="@drawable/edittext_selector" />

                    <ImageView
                        android:id="@+id/iv_clear_text"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_alignRight="@+id/tv_date"
                        android:layout_marginRight="10dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_appointment_clear_text" />


                </RelativeLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/Snow3">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:gravity="left"
                    android:text="科室名称"
                    android:textSize="16dp"
                    android:textStyle="bold" />

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="40dp">

                    <Spinner
                        android:id="@+id/sp_office"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_centerVertical="true"
                        android:textSize="18sp"
                        android:background="@drawable/edittext_selector"
                        android:spinnerMode="dialog" />

                </RelativeLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/Snow3">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:gravity="left"
                    android:text="审核状态"
                    android:textSize="16dp"
                    android:textStyle="bold" />

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="40dp">

                    <Spinner
                        android:id="@+id/sp_state"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_centerVertical="true"
                        android:textSize="18sp"
                        android:background="@drawable/edittext_selector"
                        android:spinnerMode="dropdown" />

                </RelativeLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/Snow3">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:gravity="left"
                    android:text="医生姓名"
                    android:textSize="16dp"
                    android:textStyle="bold" />

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="40dp">

                    <EditText
                        android:id="@+id/et_doctor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="请输入医生姓名"
                        android:clickable="true"
                        android:focusable="true"
                        android:textSize="18sp"
                        android:background="@drawable/edittext_selector"
                        android:imeOptions="actionSearch"
                        android:singleLine="true"/>

                    <ImageView
                        android:id="@+id/iv_search"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginRight="10dp"
                        android:layout_alignRight="@+id/et_doctor"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_office_search" />


                </RelativeLayout>

            </LinearLayout>

        </LinearLayout>

        <android.widget.Button
            android:id="@+id/btn_add_comment"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="新增评论"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/RoyalBlue"
            android:background="@drawable/btn_rect_blue"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_nomatch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:textSize="18sp"
        android:text="找不到符合条件的预约记录"
        android:textColor="@color/black"
        android:background="@color/Azure"
        android:visibility="gone"
        tools:visibility="visible" />

    <ListView
        android:id="@+id/lv_comment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />


</LinearLayout>